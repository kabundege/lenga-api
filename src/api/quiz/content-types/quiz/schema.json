      "target": "api::lesson-chapter.lesson-chapter",
      "inversedBy": "quizzes"
    },
    "audio_desc": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "audios"
      ]
    },
    "order": {
      "type": "integer",
      "required": true
    },
    "title_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "title_image_audio": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "audios"
      ]
    }
  }
}
