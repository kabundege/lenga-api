{
  "kind": "collectionType",
  "collectionName": "lesson_chapters",
  "info": {
    "singularName": "lesson-chapter",
    "pluralName": "lesson-chapters",
    "displayName": "Lesson chapter"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "text",
      "required": true
    },
    "thumbnail": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images",
        "videos"
      ]
    },
    "audio_desc": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "audios"
      ]
    },
    "lesson": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::lesson.lesson",
      "inversedBy": "lesson_chapters"
    },
    "quizzes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::quiz.quiz",
      "mappedBy": "lesson_chapter"
    },
    "lesson_video": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::lesson-video.lesson-video",
      "mappedBy": "lesson_chapter"
    },
    "order": {
      "type": "integer",
      "required": true,
      "unique": true
    }
  }
}
